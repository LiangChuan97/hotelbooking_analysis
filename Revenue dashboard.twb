    <worksheet name='Sheet 6'>
      <layout-options>
        <title>
          <formatted-text>
            <run>Bookings by Distribution Channel</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='channel_market_segment_country_performance' name='federated.11e1z2p0pu0kld11jirog1ds0aot' />
          </datasources>
          <datasource-dependencies datasource='federated.11e1z2p0pu0kld11jirog1ds0aot'>
            <column caption='Weighted Cancellation Rate(per aggregation level)' datatype='real' name='[Calculation_6230378302997995520]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ZN(SUM([cancellations])) / ZN(SUM([bookings])) * 100' />
            </column>
            <column caption='Weighted ADR (booking-weighted)' datatype='real' name='[Calculation_6230378302998294529]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([bookings] * [avg_adr]) / SUM([bookings])' />
            </column>
            <column caption='Avg Adr' datatype='real' name='[avg_adr]' role='measure' type='quantitative' />
            <column caption='Bookings' datatype='integer' name='[bookings]' role='measure' type='quantitative' />
            <column caption='Cancellations' datatype='integer' name='[cancellations]' role='measure' type='quantitative' />
            <column caption='Country' datatype='string' name='[country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column caption='Distribution Channel' datatype='string' name='[distribution_channel]' role='dimension' type='nominal' />
            <column caption='Market Segment' datatype='string' name='[market_segment]' role='dimension' type='nominal' />
            <column-instance column='[country]' derivation='None' name='[none:country:nk]' pivot='key' type='nominal' />
            <column-instance column='[distribution_channel]' derivation='None' name='[none:distribution_channel:nk]' pivot='key' type='nominal' />
            <column-instance column='[market_segment]' derivation='None' name='[none:market_segment:nk]' pivot='key' type='nominal' />
            <column-instance column='[bookings]' derivation='Sum' name='[sum:bookings:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_6230378302997995520]' derivation='User' name='[usr:Calculation_6230378302997995520:qk]' pivot='key' type='quantitative' />
            <column-instance column='[Calculation_6230378302998294529]' derivation='User' name='[usr:Calculation_6230378302998294529:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.11e1z2p0pu0kld11jirog1ds0aot].[none:distribution_channel:nk]' filter-group='5'>
            <groupfilter function='union' user:ui-domain='database' user:ui-enumeration='inclusive' user:ui-marker='enumerate'>
              <groupfilter function='member' level='[none:distribution_channel:nk]' member='&quot;Corporate&quot;' />
              <groupfilter function='member' level='[none:distribution_channel:nk]' member='&quot;Direct&quot;' />
              <groupfilter function='member' level='[none:distribution_channel:nk]' member='&quot;TA/TO&quot;' />
            </groupfilter>
