      <aliases enabled='yes' />
      <column caption='Weighted Cancellation Rate(per aggregation level)' datatype='real' name='[Calculation_6230378302997995520]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ZN(SUM([cancellations])) / ZN(SUM([bookings])) * 100' />
      </column>
      <column caption='Weighted ADR (booking-weighted)' datatype='real' name='[Calculation_6230378302998294529]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([bookings] * [avg_adr]) / SUM([bookings])' />
      </column>
      <column caption='Estimated Net Revenue (simple estimate)' datatype='real' name='[Calculation_6230378302998392834]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([bookings] * [avg_adr] * (1 - ([cancellation_rate_pct] / 100)))' />
      </column>
      <column caption='Cancellation Category (flag)' datatype='string' name='[Calculation_6230378302998487043]' role='measure' type='nominal'>
